# Copy to .env and adjust as needed. Loaded automatically at startup
# (app/__init__.py calls python-dotenv's load_dotenv()); a .env file is
# optional -- every var below has a sane default without one.

# Comma-separated list of origins allowed to call the API. Defaults to the
# frontend's Vite dev server if unset.
STRAND_CORS_ORIGINS=http://localhost:5173

# Set to "1" to skip the real Chroma embedding download and force the
# deterministic word-overlap fallback in vector_store.DenseScorer. Used by
# the test suite and CI (see tests/conftest.py, .github/workflows/ci.yml) --
# you shouldn't need this for normal local runs.
# STRAND_DISABLE_EMBEDDINGS=1

# Not used by any code yet. Working_notes.md Section 4.3.1 has the exact
# prompt drafted for the real LLM query parser (replacing query_parser.py's
# keyword-spotting stand-in) -- once that's wired up, its API key goes here.
# GEMINI_API_KEY=
# OPENAI_API_KEY=
